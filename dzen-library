<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Библиотека знаний Дзен | Энциклопедия автора</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&family=Playfair+Display:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background: #2e241f;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            font-family: 'Inter', sans-serif;
            padding: 30px 20px;
            background-image: radial-gradient(circle at 15% 30%, rgba(85, 65, 50, 0.5) 1.5%, transparent 2.5%),
                              radial-gradient(circle at 85% 70%, rgba(60, 45, 35, 0.4) 1.8%, transparent 2.2%);
            background-size: 45px 45px, 38px 38px;
        }

        .book-wrapper {
            position: relative;
            width: 100%;
            max-width: 1400px;
            background: transparent;
        }

        /* ГЛАВНОЕ ОГЛАВЛЕНИЕ — панель навигации сверху */
        .toc-panel {
            background: #fef3e4;
            border-radius: 60px;
            margin-bottom: 28px;
            padding: 14px 24px;
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 12px 20px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.15), inset 0 1px 0 rgba(255,255,240,0.8);
            backdrop-filter: blur(2px);
            border: 1px solid #e7cfb5;
        }

        .toc-link {
            background: transparent;
            border: none;
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            font-size: 0.85rem;
            padding: 6px 16px;
            border-radius: 40px;
            color: #5a3e2a;
            cursor: pointer;
            transition: all 0.2s ease;
            letter-spacing: 0.3px;
            background: #fffaf2;
            box-shadow: 0 1px 2px rgba(0,0,0,0.05);
        }

        .toc-link:hover {
            background: #e7d1ba;
            color: #2c1a10;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

        .book-container {
            position: relative;
            width: 100%;
            height: 78vh;
            min-height: 580px;
            background: transparent;
            perspective: 2200px;
        }

        .book {
            position: relative;
            width: 100%;
            height: 100%;
            transform-style: preserve-3d;
        }

        .page {
            position: absolute;
            width: 100%;
            height: 100%;
            top: 0;
            left: 0;
            transform-style: preserve-3d;
            transform-origin: left center;
            transition: transform 0.65s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            backface-visibility: hidden;
            z-index: 10;
        }

        .page-front {
            position: absolute;
            width: 100%;
            height: 100%;
            background: #fffbf4;
            background-image: linear-gradient(145deg, #fffcf5 0%, #fff7ec 100%);
            box-shadow: 0 25px 40px -18px rgba(0,0,0,0.35), inset 0 0 0 1px rgba(215, 185, 135, 0.5);
            border-radius: 6px 14px 14px 6px;
            padding: 32px 42px 38px 48px;
            overflow-y: auto;
            backface-visibility: hidden;
            font-family: 'Inter', sans-serif;
            color: #2d241d;
            scrollbar-width: thin;
        }

        .page-front::-webkit-scrollbar {
            width: 5px;
            background: #eaddcd;
        }
        .page-front::-webkit-scrollbar-thumb {
            background: #c0a07a;
            border-radius: 10px;
        }

        /* Единый стиль для всех глав и заголовков */
        h1, h2, h3, .chapter-head {
            font-family: 'Playfair Display', serif;
            letter-spacing: -0.2px;
        }

        /* Заголовки страниц — единый теплый цвет */
        .ency-title {
            font-size: 2.2rem;
            font-weight: 700;
            color: #b4602c;
            margin-bottom: 0.6rem;
            margin-top: 0;
            border-left: 5px solid #dc9e65;
            padding-left: 18px;
            background: none;
            -webkit-background-clip: unset;
            background-clip: unset;
            color: #b4602c;
        }

        .chapter-badge {
            display: inline-block;
            background: #ecdbbc;
            padding: 4px 18px;
            border-radius: 50px;
            font-size: 0.75rem;
            font-weight: 700;
            color: #7c571f;
            margin: 18px 0 12px 0;
            letter-spacing: 0.4px;
            text-transform: uppercase;
        }

        .glossary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(270px, 1fr));
            gap: 14px;
            margin: 20px 0;
        }

        .term {
            background: #fef5ea;
            border-left: 4px solid #dc9e65;
            padding: 10px 14px;
            border-radius: 14px;
            font-size: 0.88rem;
            transition: all 0.2s;
        }

        .term strong {
            font-weight: 700;
            color: #b1551c;
            font-family: monospace;
        }

        /* кнопки навигации */
        .navigation {
            position: absolute;
            bottom: 15px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: center;
            gap: 25px;
            z-index: 55;
            pointer-events: none;
        }

        .nav-btn {
            pointer-events: auto;
            background: #5e4230;
            border: none;
            padding: 10px 28px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 0.9rem;
            color: #fff2e4;
            cursor: pointer;
            transition: 0.2s;
            box-shadow: 0 6px 12px rgba(0,0,0,0.2);
            backdrop-filter: blur(2px);
        }

        .nav-btn:hover {
            background: #8b5e40;
            transform: scale(0.96);
        }

        .page-counter {
            position: absolute;
            bottom: 22px;
            right: 45px;
            font-size: 0.75rem;
            color: #b68b60;
            font-family: monospace;
            z-index: 35;
            background: rgba(255, 248, 235, 0.8);
            padding: 3px 14px;
            border-radius: 50px;
            backdrop-filter: blur(3px);
        }

        .highlight {
            background: #f5e5d3;
            padding: 0 4px;
            font-weight: 600;
            border-radius: 6px;
        }

        hr {
            margin: 18px 0;
            border: none;
            height: 1px;
            background: #e6d5be;
        }

        /* доп анимация при наведении на страницу */
        .page:hover .page-front {
            transition: box-shadow 0.25s ease;
            box-shadow: 0 28px 45px -15px rgba(0,0,0,0.4), inset 0 0 0 1px #e7d0b0;
        }

        /* кнопка возврата в оглавление */
        .back-to-toc {
            position: sticky;
            bottom: 12px;
            float: right;
            background: #e9d5be;
            border: none;
            font-size: 0.75rem;
            padding: 6px 14px;
            border-radius: 40px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
            color: #51371f;
            margin-top: 20px;
            margin-right: 5px;
        }
        .back-to-toc:hover {
            background: #cfa67b;
            color: white;
            transform: translateY(-3px);
        }

        @media (max-width: 780px) {
            .page-front {
                padding: 22px 22px 28px 28px;
            }
            .ency-title {
                font-size: 1.6rem;
            }
            .glossary-grid {
                grid-template-columns: 1fr;
            }
            .toc-link {
                font-size: 0.7rem;
                padding: 4px 12px;
            }
            .toc-panel {
                padding: 10px 16px;
                gap: 8px;
            }
            .nav-btn {
                padding: 6px 20px;
            }
        }
    </style>
</head>
<body>
<div class="book-wrapper">
    <!-- Панель оглавления (гиперссылки) -->
    <div class="toc-panel" id="tocPanel">
        <button class="toc-link" data-page="0">📖 Вступление</button>
        <button class="toc-link" data-page="1">📘 Словарь (1-15)</button>
