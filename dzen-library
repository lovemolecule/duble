            🌟 Дзен — марафон. Изучайте метрики, тестируйте идеи, растите.
            </div>
            <button class="back-to-toc" onclick="window.scrollTo({top:0,behavior:'smooth'}); document.getElementById('tocPanel').scrollIntoView({behavior:'smooth'});">📖 К содержанию</button>
        </div>`
    ];

    const total = pagesHTML.length;
    let currentIdx = 0;
    let audioCtx = null;

    const bookDiv = document.getElementById('book');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    const counterSpan = document.getElementById('pageCounter');
    let pageElements = [];

    // Инициализация книги
    function buildBook() {
        bookDiv.innerHTML = '';
        pageElements = [];
        for (let i = 0; i < total; i++) {
            const pageDiv = document.createElement('div');
            pageDiv.className = 'page';
            const front = document.createElement('div');
            front.className = 'page-front';
            front.innerHTML = pagesHTML[i];
            pageDiv.appendChild(front);
            if (i === 0) {
                pageDiv.style.transform = 'rotateY(0deg)';
                pageDiv.style.pointerEvents = 'auto';
            } else {
                pageDiv.style.transform = 'rotateY(180deg)';
                pageDiv.style.pointerEvents = 'none';
            }
            pageDiv.style.zIndex = total - i;
            bookDiv.appendChild(pageDiv);
            pageElements.push(pageDiv);
        }
        updateCounter();
    }

    // шелест (звуковой эффект)
    function playRustle() {
        try {
            if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            if (audioCtx.state === 'suspended') audioCtx.resume();
            const now = audioCtx.currentTime;
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.type = 'sine';
            osc.frequency.value = 410;
            gain.gain.value = 0.07;
            osc.start();
            gain.gain.exponentialRampToValueAtTime(0.0001, now + 0.18);
            osc.stop(now + 0.18);
            const buf = 2048;
            const noise = audioCtx.createScriptProcessor(buf, 1, 1);
            noise.onaudioprocess = function(e) {
                const out = e.outputBuffer.getChannelData(0);
                for (let i = 0; i < buf; i++) out[i] = (Math.random() - 0.5) * 0.055;
                noise.disconnect();
            };
            noise.connect(audioCtx.destination);
            setTimeout(() => noise.disconnect(), 100);
        } catch(e) {}
    }

    function flip(delta) {
        const newIdx = currentIdx + delta;
        if (newIdx < 0 || newIdx >= total) return;
        playRustle();
        const cur = pageElements[currentIdx];
        const nxt = pageElements[newIdx];
        if (delta === 1) {
            cur.style.transform = 'rotateY(-180deg)';
            nxt.style.transform = 'rotateY(0deg)';
        } else {
            cur.style.transform = 'rotateY(180deg)';
            nxt.style.transform = 'rotateY(0deg)';
        }
        cur.style.pointerEvents = 'none';
        nxt.style.pointerEvents = 'auto';
        cur.style.zIndex = total - currentIdx;
        nxt.style.zIndex = total - newIdx;
        currentIdx = newIdx;
        updateCounter();
        setTimeout(() => { if (Math.random() > 0.6) playRustle(); }, 140);
    }

    function updateCounter() {
        counterSpan.innerText = `стр. ${currentIdx+1} / ${total}`;
    }

    // гиперссылки оглавления
    function jumpToPage(pageIndex) {
        if (pageIndex === currentIdx) return;
        // плавное перелистывание до нужной страницы
        while (currentIdx !== pageIndex) {
            const dir = pageIndex > currentIdx ? 1 : -1;
            const newIdx = currentIdx + dir;
            if (newIdx < 0 || newIdx >= total) break;
            const cur = pageElements[currentIdx];
            const nxt = pageElements[newIdx];
            if (dir === 1) {
                cur.style.transform = 'rotateY(-180deg)';
                nxt.style.transform = 'rotateY(0deg)';
            } else {
                cur.style.transform = 'rotateY(180deg)';
                nxt.style.transform = 'rotateY(0deg)';
            }
            cur.style.pointerEvents = 'none';
            nxt.style.pointerEvents = 'auto';
            cur.style.zIndex = total - currentIdx;
            nxt.style.zIndex = total - newIdx;
            currentIdx = newIdx;
            updateCounter();
            playRustle();
        }
    }

    buildBook();

    // Кнопки листания
    prevBtn.addEventListener('click', () => flip(-1));
    nextBtn.addEventListener('click', () => flip(1));

    // Обработчики для панели оглавления
    document.querySelectorAll('.toc-link').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const pageNum = parseInt(btn.getAttribute('data-page'), 10);
            if (!isNaN(pageNum)) jumpToPage(pageNum);
        });
    });

    // Активация аудио после взаимодействия
    function enableAudio() {
        if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
        document.body.removeEventListener('click', enableAudio);
        document.body.removeEventListener('touchstart', enableAudio);
    }
    document.body.addEventListener('click', enableAudio);
    document.body.addEventListener('touchstart', enableAudio);

    // Стрелки клавиатуры
    window.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') { flip(-1); e.preventDefault(); }
        if (e.key === 'ArrowRight') { flip(1); e.preventDefault(); }
    });
</script>
</body>
</html>
